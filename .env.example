# Beecause — open-source self-host configuration.
# Copy to .env and fill in. No Google Cloud required.

# --- Persistence: Postgres ---
STORE_BACKEND=postgres
DATABASE_URL=postgres://beecause:beecause@localhost:5432/beecause

# --- Vector search ---
VECTOR_BACKEND=pgvector      # persistent, via Postgres + the pgvector extension (recommended)
# VECTOR_BACKEND=inmemory    # non-persistent in-memory index (dev/eval only)
# VECTOR_DIM=768             # embedding dimension (default 768)

# --- Auth: single-tenant ---
TENANT_MODE=single
AUTH_BACKEND=local           # 'local' (email/password) or 'oidc'
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
# LOCAL_SIGNUP_ENABLED=true  # allow self-serve registration at /auth/register

# --- Auth: generic OIDC (when AUTH_BACKEND=oidc) ---
# OIDC_ISSUER=https://your-idp.example.com
# OIDC_CLIENT_ID=beecause
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_ALLOW_UNVERIFIED_EMAIL=false

# --- Server ---
SESSION_SECRET=replace-with-a-random-string-at-least-32-chars
BASE_URL=http://localhost:3000
PORT=8080

# --- BYOK: bring your own LLM key (choose one) ---
# ANTHROPIC_API_KEY=...
# OPENAI_API_KEY=...
